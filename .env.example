# ollama-asr configuration — copy to .env and adjust.
OLLAMA_URL=http://localhost:11434/v1/audio/transcriptions
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=hf.co/ggml-org/Qwen3-ASR-1.7B-GGUF:Q8_0

# Languages you can cycle through with Tab, as ISO-639-1 codes separated by
# commas (e.g. "fr,en"). "auto" (let the model detect) is always prepended.
LANGUAGES=fr,en
