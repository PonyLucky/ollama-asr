# ollama-asr configuration — copy to .env and adjust
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/ggml-org/Qwen3-ASR-1.7B-GGUF:Q8_0

FALLBACK_OLLAMA_URL=http://localhost:11434
FALLBACK_OLLAMA_MODEL=hf.co/ggml-org/Qwen3-ASR-1.7B-GGUF:Q8_0

# Languages (ISO-639-1 codes separated by commas (e.g. "fr,en")
LANGUAGES=fr,en

# Global start/stop shortcut:
# - bind `run.sh --toggle` to a key in your desktop settings: it toggles
#   recording in the running app, or launches it (and starts recording) if none
#   is running yet
# - Leave it blank/unset to disable
SHORTCUT_RECORD_HINT=Meta+R

# Maximum recording duration in seconds before auto-stop (guard against accidentally
# recording for hours, e.g. if triggered by a global shortcut and walked away). 0 or empty
# disables the limit. Default is 300 (5 minutes).
#OLLAMA_ASR_MAX_REC=300
